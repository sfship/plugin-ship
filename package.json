{
  "name": "plugin-ship",
  "description": "Salesforce CLI plugin for managing the full development and release lifecycle of second-generation managed and unlocked packages.",
  "version": "1.0.0",
  "dependencies": {
    "@napi-rs/keyring": "^1.2.0",
    "@oclif/core": "^4",
    "@salesforce/core": "^8.2.7",
    "@salesforce/sf-plugins-core": "^12",
    "@salesforce/source-deploy-retrieve": "^12.31.21",
    "jszip": "^3.10.1",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oclif/plugin-command-snapshot": "^5.3.15",
    "@salesforce/cli-plugins-testkit": "^5.3.50",
    "@salesforce/dev-scripts": "^11.0.4",
    "@types/dedent": "^0.7.2",
    "c8": "^11.0.0",
    "dedent": "^1.7.2",
    "eslint-plugin-sf-plugin": "^1.20.32",
    "esmock": "^2.7.3",
    "oclif": "^4.22.96",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/lib",
    "/messages",
    "/oclif.manifest.json",
    "/oclif.lock"
  ],
  "keywords": [
    "force",
    "salesforce",
    "salesforcedx",
    "sf",
    "sf-plugin",
    "sfdx",
    "sfdx-plugin"
  ],
  "license": "Apache-2.0",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "ship": {
        "description": "Manage and run the full development and release lifecycle.",
        "subtopics": {
          "flow": {
            "description": "Manage and run flows defined in ship.yml."
          },
          "task": {
            "description": "Manage and run individual tasks."
          },
          "service": {
            "description": "Manage external service connections.",
            "subtopics": {
              "connect": {
                "description": "Connect an external service."
              }
            }
          }
        }
      }
    },
    "flexibleTaxonomy": true
  },
  "scripts": {
    "build": "wireit",
    "clean": "sf-clean",
    "clean-all": "sf-clean all",
    "compile": "wireit",
    "docs": "sf-docs",
    "fix-license": "eslint src test --fix --rule \"header/header: [2]\"",
    "format": "wireit",
    "link-check": "wireit",
    "lint": "wireit",
    "postpack": "sf-clean --ignore-signing-artifacts",
    "prepack": "sf-prepack",
    "prepare": "sf-install",
    "test": "wireit",
    "test:nuts": "c8 mocha \"**/*.nut.ts\" --slow 4500 --timeout 600000 --parallel",
    "test:only": "wireit",
    "version": "oclif readme"
  },
  "publishConfig": {
    "access": "public"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "compile",
        "lint"
      ]
    },
    "copy-assets": {
      "command": "node -e \"require('fs').cpSync('src/core/flows', 'lib/core/flows', {recursive: true, force: true})\"",
      "files": [
        "src/core/flows/**/*.yml"
      ],
      "output": [
        "lib/core/flows/**/*.yml"
      ]
    },
    "compile": {
      "command": "tsc -p . --pretty --incremental && tsc-alias -p tsconfig.json",
      "files": [
        "src/**/*.ts",
        "**/tsconfig.json",
        "messages/**"
      ],
      "output": [
        "lib/**",
        "*.tsbuildinfo"
      ],
      "clean": "if-file-deleted"
    },
    "format": {
      "command": "prettier --write \"+(src|test|schemas)/**/*.+(ts|js|json)|command-snapshot.json\"",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "schemas/**/*.json",
        "command-snapshot.json",
        ".prettier*"
      ],
      "output": []
    },
    "lint": {
      "command": "eslint src test --color --cache --cache-location .eslintcache",
      "files": [
        "src/**/*.ts",
        "test/**/*.ts",
        "messages/**",
        "**/.eslint*",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "test:compile": {
      "command": "tsc -p \"./test\" --pretty",
      "files": [
        "test/**/*.ts",
        "**/tsconfig.json"
      ],
      "output": []
    },
    "test": {
      "dependencies": [
        "test:compile",
        "test:only",
        "lint"
      ]
    },
    "test:only": {
      "command": "c8 mocha \"test/**/*.test.ts\"",
      "env": {
        "FORCE_COLOR": "2"
      },
      "files": [
        "test/**/*.ts",
        "src/**/*.ts",
        "**/tsconfig.json",
        ".mocha*",
        "!*.nut.ts"
      ],
      "output": []
    },
    "test:command-reference": {
      "command": "node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" commandreference:generate --erroronwarnings",
      "files": [
        "src/**/*.ts",
        "messages/**",
        "package.json"
      ],
      "output": [
        "tmp/root"
      ]
    },
    "test:deprecation-policy": {
      "command": "node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" snapshot:compare",
      "files": [
        "src/**/*.ts"
      ],
      "output": [],
      "dependencies": [
        "compile"
      ]
    },
    "test:json-schema": {
      "command": "node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" schema:compare",
      "files": [
        "src/**/*.ts",
        "schemas"
      ],
      "output": []
    },
    "link-check": {
      "command": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || linkinator \"**/*.md\" --skip \"CHANGELOG.md|node_modules|test/|confluence.internal.salesforce.com|my.salesforce.com|localhost|%s\" --markdown --retry --directory-listing --verbosity error",
      "files": [
        "./*.md",
        "./!(CHANGELOG).md",
        "messages/**/*.md"
      ],
      "output": []
    }
  },
  "exports": {
    ".": "./lib/index.js",
    "./core": "./lib/core/index.js",
    "./core/*": "./lib/core/*.js"
  },
  "type": "module",
  "author": "sfship"
}
