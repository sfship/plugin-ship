{
  "test": {
    "testsPath": "test/**/*.test.ts"
  },
  "wireit": {
    "build": {
      "dependencies": ["compile", "lint", "copy-assets"]
    },
    "copy-assets": {
      "command": "node -e \"const fs=require('fs');fs.cpSync('src/core/flows','lib/core/flows',{recursive:true,force:true});fs.cpSync('src/core/templates','lib/core/templates',{recursive:true,force:true})\"",
      "dependencies": ["compile"],
      "files": ["src/core/flows/**/*.yml", "src/core/templates/**/*"],
      "output": ["lib/core/flows/**/*.yml", "lib/core/templates/**/*"]
    },
    "test": {
      "dependencies": ["test:compile", "test:only", "lint"]
    },
    "test:only": {
      "command": "c8 mocha \"test/**/*.test.ts\"",
      "env": { "FORCE_COLOR": "2" },
      "files": ["test/**/*.ts", "src/**/*.ts", "**/tsconfig.json", ".mocha*", "!*.nut.ts", ".nycrc"],
      "output": []
    }
  },
  "scripts": {
    "docs": "yarn --cwd docs dev"
  },
  "license": "Apache-2.0"
}
